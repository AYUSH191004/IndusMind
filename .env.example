APP_NAME=Industrial Knowledge Intelligence Platform

APP_VERSION=1.0.0

ENVIRONMENT=development

DEBUG=true

API_PREFIX=/api/v1

HOST=0.0.0.0

PORT=8000

LOG_LEVEL=INFO

POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/knowledge

REDIS_URL=redis://redis:6379/0

NEO4J_URI=bolt://neo4j:7687

NEO4J_USER=neo4j

NEO4J_PASSWORD=password

QDRANT_URL=http://qdrant:6333

SECRET_KEY=replace-with-strong-secret

ACCESS_TOKEN_EXPIRE_MINUTES=30