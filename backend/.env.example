# =============================================================================
# Application
# =============================================================================

APP_NAME=Industrial Knowledge Intelligence Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

API_PREFIX=/api/v1

# =============================================================================
# Security
# =============================================================================

# Generate a strong secret (minimum 32 characters)
SECRET_KEY=change_this_to_a_secure_random_secret_key

ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# =============================================================================
# PostgreSQL
# =============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432

POSTGRES_DB=industrial_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# SQLAlchemy Async URL
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/industrial_db

# =============================================================================
# Redis
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

REDIS_URL=redis://redis:6379/0

# =============================================================================
# Neo4j
# =============================================================================

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# =============================================================================
# Qdrant
# =============================================================================

QDRANT_HOST=qdrant
QDRANT_PORT=6333

QDRANT_URL=http://qdrant:6333

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# CORS
# =============================================================================

BACKEND_CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Celery
# =============================================================================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# AI / Embeddings
# =============================================================================

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# LLM
# =============================================================================

GROQ_API_KEY=your_groq_api_key

# =============================================================================
# File Upload
# =============================================================================

MAX_UPLOAD_SIZE_MB=100

# =============================================================================
# Observability
# =============================================================================

ENABLE_METRICS=false
ENABLE_TRACING=false

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_BACKGROUND_JOBS=true
ENABLE_CACHE=true
ENABLE_VECTOR_SEARCH=true
ENABLE_GRAPH_SEARCH=true